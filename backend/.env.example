# OpenAI API key for the Campaign Insights feature (Part 2).
# Create one at https://platform.openai.com/api-keys
# Copy this file to .env and fill in your key. .env is gitignored.
OPENAI_API_KEY=your_key_here

# Optional: override the model used for insights (defaults to gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini
